{
  "manifest_version": 3,
  "name": "Connect.Me",
  "description": "Privacy-first site presence, consent-driven browsing controls, and professional networking powered by Supabase.",
  "version": "1.1.0",
  "minimum_chrome_version": "114",
  "action": {
    "default_title": "Connect.Me",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/branding/generated/chrome/icon-16.png",
      "32": "assets/branding/generated/chrome/icon-32.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "options_page": "options.html",
  "permissions": [
    "storage",
    "tabs",
    "alarms",
    "windows"
  ],
  "host_permissions": [
    "https://dhmtljnjygcqzjrhhscu.supabase.co/*"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "styles.css",
        "privacy.html"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "icons": {
    "16": "assets/branding/generated/chrome/icon-16.png",
    "32": "assets/branding/generated/chrome/icon-32.png",
    "48": "assets/branding/generated/chrome/icon-48.png",
    "128": "assets/branding/generated/chrome/icon-128.png"
  }
}
