{
  "manifest_version": 3,
  "name": "Connect.Me",
  "description": "Privacy-first site presence and optional browsing history tracking powered by Supabase.",
  "version": "1.0.0",
  "minimum_chrome_version": "114",
  "action": {
    "default_title": "Connect.Me",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "options_page": "options.html",
  "permissions": [
    "storage",
    "tabs",
    "alarms"
  ],
  "optional_host_permissions": [
    "https://*/*",
    "http://localhost/*"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "styles.css",
        "privacy.html"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
